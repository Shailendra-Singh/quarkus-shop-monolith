### --- Build & Output --- ###
target/
bin/
build/
out/
.gradle/
.flattened-pom.xml
# Ignore crash logs
hs_err_pid*
replay_pid*

### --- Maven Wrapper --- ###
# We keep the wrapper scripts and config, but usually keep the JAR
# unless you want to force users to download it.
# !.mvn/wrapper/maven-wrapper.jar

### --- IDEs (IntelliJ, Eclipse, NetBeans, VS Code) --- ###
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache
.apt_generated
.vscode/
*.code-workspace
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/
nb-configuration.xml

### --- Secrets & Environment --- ###
.env
.env.local
**/*secret.yaml
**/*secret.yml
.certs/
# Exclude sensitive Kubernetes/Terraform files if applicable
.terraform/

### --- OS & Editors --- ###
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig
*.rej

### --- Logs --- ###
*.log
logs/

### --- Packaging --- ###
# We ignore finished artifacts because they are generated from source
*.jar
*.war
*.ear
*.zip
*.tar.gz
# Ensure we don't ignore the Maven Wrapper JAR if you chose to keep it above
# !.mvn/wrapper/maven-wrapper.jar